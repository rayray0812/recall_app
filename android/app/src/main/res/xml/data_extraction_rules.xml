<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto-backup and device-to-device transfer are disabled for this app.
  Encrypted Hive data + secure-storage keys must never leave the device via
  Google's backup transport, so both cloud-backup and device-transfer are
  fully excluded.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
